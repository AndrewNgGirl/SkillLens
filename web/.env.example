# SkillLens self-hosted configuration.
# Copy this file to .env.local and fill your own keys.
# Never commit .env.local. Never expose keys with NEXT_PUBLIC_* variables.

# Optional: Anthropic / Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: disabled is faster and cheaper; enabled may improve harder semantic judgments.
LLM_THINKING_MODE=disabled

# Optional: request timeout in milliseconds.
LLM_TIMEOUT_MS=180000
MARKET_LLM_TIMEOUT_MS=20000

# Optional: per-IP daily deep-review limit for deployed instances.
DAILY_SCORE_LIMIT=20
MAX_INPUT_CHARS=50000

# Optional: set to 0 in production if you do not want local/private IP bypass.
LLM_BYPASS_LOCAL=0

# Optional: increases GitHub Search API rate limit.
GITHUB_TOKEN=
MARKET_CACHE_TTL_MS=1800000

# Optional: Supabase, used only if you enable public sharing or import caching.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
