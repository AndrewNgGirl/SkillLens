{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StockSignalReport",
  "type": "object",
  "required": [
    "market_date",
    "scenario",
    "summary",
    "risk_disclaimer",
    "theme_rankings",
    "watchlist",
    "data_quality"
  ],
  "properties": {
    "market_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "scenario": {
      "type": "string",
      "enum": ["theme_rotation", "watchlist", "risk_audit", "education"]
    },
    "summary": { "type": "string", "maxLength": 300 },
    "risk_disclaimer": { "type": "string", "minLength": 20 },
    "theme_rankings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["theme", "score", "evidence", "risks", "confidence"],
        "properties": {
          "theme": { "type": "string" },
          "score": { "type": "number", "minimum": 0, "maximum": 100 },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "risks": { "type": "array", "items": { "type": "string" } },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "watchlist": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "code",
          "name",
          "role",
          "signal_score",
          "risk_level",
          "evidence",
          "invalidations",
          "human_review_required"
        ],
        "properties": {
          "code": { "type": "string" },
          "name": { "type": "string" },
          "role": { "type": "string" },
          "signal_score": { "type": "number", "minimum": 0, "maximum": 100 },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "invalidations": { "type": "array", "items": { "type": "string" } },
          "human_review_required": { "type": "boolean" }
        }
      }
    },
    "data_quality": {
      "type": "object",
      "required": ["freshness", "source_count", "missing_fields", "confidence"],
      "properties": {
        "freshness": {
          "type": "string",
          "enum": ["same_session", "previous_session", "stale", "unknown"]
        },
        "source_count": { "type": "integer", "minimum": 0 },
        "missing_fields": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  },
  "additionalProperties": true
}
